	function WindowFunctions:Unload()
		if onUnloadedCallback then onUnloadedCallback() end
		unloaded = true
		if base then base:Destroy() end
		if windowState and windowState.Connection then windowState.Connection:Disconnect() end
	end

	function WindowFunctions:SetKeybind(keybind)
		Settings.Keybind = keybind
		if windowState and windowState.Connection then windowState.Connection:Disconnect() end
		windowState = {Connection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
			if not gameProcessed and input.KeyCode == keybind then
				base.Enabled = not base.Enabled
			end
		end)}
	end

