					local stroke = t.Button:FindFirstChildOfClass("UIStroke")
					if stroke then stroke:Destroy() end
					t.Icon.ImageTransparency = 0.5
					t.NameLabel.TextTransparency = 0.5
					t.Content.Visible = false
				end
				
				local activeGrad = Instance.new("UIGradient")
				activeGrad.Color = ColorSequence.new{
					ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
					ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255))
				}
				activeGrad.Transparency = NumberSequence.new(0.88, 0.94)
				activeGrad.Rotation = 135
				activeGrad.Parent = tabBtn
				
				local stroke = Instance.new("UIStroke")
				stroke.Color = Color3.fromRGB(255, 255, 255)
				stroke.Transparency = 0.88
				stroke.Parent = tabBtn
				
				tabBtn.BackgroundTransparency = 0
				tabIcon.ImageTransparency = 0
				tabName.TextTransparency = 0.1
				tabContent.Visible = true
				
				currentTabLabel.Text = tabSettings.Name
			end
			
			tabBtn.MouseButton1Click:Connect(selectTab)
			
			if tabIndex == 1 then
				selectTab()
			end
			
			table.insert(tabsList, {
				Button = tabBtn,
				Icon = tabIcon,
				NameLabel = tabName,
				Content = tabContent,
				Left = leftSection,
				Right = rightSection
			})
			
			function TabFunctions:Section(sectionSettings)
				local SectionFunctions = {}
				local parentSection = sectionSettings.Side == "Right" and rightSection or leftSection
				
				local sectionPanel = Instance.new("Frame")
				sectionPanel.Name = (sectionSettings.Name or "Section") .. "Panel"
				sectionPanel.AutomaticSize = Enum.AutomaticSize.Y
				sectionPanel.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
				sectionPanel.BackgroundTransparency = 0.97
				sectionPanel.BorderSizePixel = 0
				sectionPanel.Size = UDim2.new(1, 0, 0, 0)
				sectionPanel.Parent = parentSection
				
				local panelCorner = Instance.new("UICorner")
				panelCorner.CornerRadius = UDim.new(0, 12)
				panelCorner.Parent = sectionPanel
				
				glassStroke(sectionPanel, 0.93)
				
				local panelPadding = Instance.new("UIPadding")
				panelPadding.PaddingBottom = UDim.new(0, 16)
				panelPadding.PaddingLeft = UDim.new(0, 16)
				panelPadding.PaddingRight = UDim.new(0, 16)
				panelPadding.PaddingTop = UDim.new(0, 16)
				panelPadding.Parent = sectionPanel
				
				local panelList = Instance.new("UIListLayout")
				panelList.Padding = UDim.new(0, 12)
				panelList.Parent = sectionPanel
				
				function SectionFunctions:Header(headerSettings)
					local headerContainer = Instance.new("Frame")
					headerContainer.Name = "Header"
					headerContainer.BackgroundTransparency = 1
					headerContainer.Size = UDim2.new(1, 0, 0, 30)
					headerContainer.Parent = sectionPanel
					
					local headerText = Instance.new("TextLabel")
					headerText.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Bold)
					headerText.Text = (headerSettings.Text or ""):upper()
					headerText.TextColor3 = Color3.fromRGB(255, 255, 255)
					headerText.TextSize = 11
					headerText.TextTransparency = 0.4
					headerText.TextXAlignment = Enum.TextXAlignment.Left
					headerText.BackgroundTransparency = 1
					headerText.Size = UDim2.new(1, 0, 0, 18)
					headerText.Parent = headerContainer
					
					local divider = Instance.new("Frame")
					divider.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
					divider.BackgroundTransparency = 0.92
					divider.BorderSizePixel = 0
					divider.Position = UDim2.fromOffset(0, 24)
					divider.Size = UDim2.new(1, 0, 0, 1)
					divider.Parent = headerContainer
				end
				
				function SectionFunctions:Row(rowSettings, flag)
					local RowFunctions = {Value = rowSettings.Value or "—"}
					
					local row = Instance.new("Frame")
					row.Name = "Row"
					row.BackgroundTransparency = 1
					row.Size = UDim2.new(1, 0, 0, 24)
					row.Parent = sectionPanel
					
					local label = Instance.new("TextLabel")
					label.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json")
					label.Text = rowSettings.Label or "Label"
					label.TextColor3 = Color3.fromRGB(150, 150, 150)
					label.TextSize = 13
					label.TextXAlignment = Enum.TextXAlignment.Left
					label.BackgroundTransparency = 1
					label.Size = UDim2.new(1, -60, 1, 0)
					label.Parent = row
					
					local value = Instance.new("TextLabel")
					value.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json")
					value.Text = rowSettings.Value or "—"
					value.TextColor3 = Color3.fromRGB(255, 255, 255)
					value.TextSize = 13
					value.TextXAlignment = Enum.TextXAlignment.Right
					value.TextTransparency = 0.3
					value.BackgroundTransparency = 1
					value.AnchorPoint = Vector2.new(1, 0)
					value.Position = UDim2.fromScale(1, 0)
					value.Size = UDim2.fromOffset(60, 24)
					value.Parent = row
					
					function RowFunctions:SetValue(newValue)
						value.Text = newValue or "—"
						RowFunctions.Value = newValue
					end
					
					if flag then CryptHub.Options[flag] = RowFunctions end
					return RowFunctions
				end
				
				function SectionFunctions:StatusBadge(badgeSettings)
					local badge = Instance.new("TextLabel")
					badge.Name = "StatusBadge"
					badge.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json")
					badge.Text = badgeSettings.Value or "Online"
					badge.TextColor3 = Color3.fromRGB(45, 143, 78)
					badge.TextSize = 11
					badge.BackgroundColor3 = Color3.fromRGB(45, 143, 78)
					badge.BackgroundTransparency = 0.8
					badge.BorderSizePixel = 0
					badge.Size = UDim2.fromOffset(50, 20)
					badge.Parent = sectionPanel
					
					local corner = Instance.new("UICorner")
					corner.CornerRadius = UDim.new(1, 0)
					corner.Parent = badge
				end
				
				function SectionFunctions:Button(btnSettings, flag)
					local btn = Instance.new("TextButton")
					btn.Name = "Button"
					btn.Text = ""
					btn.AutoButtonColor = false
					btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
					btn.BackgroundTransparency = 0.92
					btn.BorderSizePixel = 0
					btn.Size = UDim2.new(1, 0, 0, 32)
					btn.Parent = sectionPanel
					
					local corner = Instance.new("UICorner")
					corner.CornerRadius = UDim.new(0, 8)
					corner.Parent = btn
					
					glassStroke(btn, 0.9)
					
					local label = Instance.new("TextLabel")
					label.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json")
					label.Text = btnSettings.Name or "Button"
					label.TextColor3 = Color3.fromRGB(255, 255, 255)
					label.TextSize = 13
					label.TextTransparency = 0.5
					label.BackgroundTransparency = 1
					label.Size = UDim2.fromScale(1, 1)
					label.Parent = btn
					
					btn.MouseButton1Click:Connect(function()
						if btnSettings.Callback then btnSettings.Callback() end
					end)
					
					if flag then
						CryptHub.Options[flag] = {Class = "Button", Click = function() btnSettings.Callback() end}
					end
				end
				
				function SectionFunctions:Toggle(toggleSettings, flag)
					local ToggleFunctions = {Value = toggleSettings.Default or false}
					
					local toggleRow = Instance.new("Frame")
					toggleRow.Name = "Toggle"
					toggleRow.BackgroundTransparency = 1
					toggleRow.Size = UDim2.new(1, 0, 0, 28)
					toggleRow.Parent = sectionPanel
					
					local label = Instance.new("TextLabel")
					label.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json")
					label.Text = toggleSettings.Name or "Toggle"
					label.TextColor3 = Color3.fromRGB(150, 150, 150)
					label.TextSize = 13
					label.TextXAlignment = Enum.TextXAlignment.Left
					label.BackgroundTransparency = 1
					label.Size = UDim2.new(1, -50, 1, 0)
					label.Parent = toggleRow
					
					local switch = Instance.new("TextButton")
					switch.Name = "Switch"
					switch.Text = ""
					switch.AutoButtonColor = false
					switch.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
					switch.BackgroundTransparency = 0.85
					switch.BorderSizePixel = 0
					switch.AnchorPoint = Vector2.new(1, 0.5)
					switch.Position = UDim2.fromScale(1, 0.5)
					switch.Size = UDim2.fromOffset(36, 20)
					switch.Parent = toggleRow
					
					local switchCorner = Instance.new("UICorner")
					switchCorner.CornerRadius = UDim.new(1, 0)
					switchCorner.Parent = switch
					
					local knob = Instance.new("Frame")
					knob.Name = "Knob"
					knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
					knob.BorderSizePixel = 0
					knob.Position = UDim2.fromOffset(2, 2)
					knob.Size = UDim2.fromOffset(16, 16)
					knob.Parent = switch
					
					local knobCorner = Instance.new("UICorner")
					knobCorner.CornerRadius = UDim.new(1, 0)
					knobCorner.Parent = knob
					
					local on = toggleSettings.Default or false
					
					local function updateToggle(instant)
						if on then
							Tween(switch, TweenInfo.new(instant and 0 or 0.3), {BackgroundTransparency = 0.15}):Play()
							Tween(knob, TweenInfo.new(instant and 0 or 0.3), {Position = UDim2.fromOffset(18, 2), BackgroundColor3 = Color3.fromRGB(17, 17, 17)}):Play()
						else
							Tween(switch, TweenInfo.new(instant and 0 or 0.3), {BackgroundTransparency = 0.85}):Play()
							Tween(knob, TweenInfo.new(instant and 0 or 0.3), {Position = UDim2.fromOffset(2, 2), BackgroundColor3 = Color3.fromRGB(255, 255, 255)}):Play()
						end
						ToggleFunctions.Value = on
						if toggleSettings.Callback then toggleSettings.Callback(on) end
					end
					
					if on then
						switch.BackgroundTransparency = 0.15
						knob.Position = UDim2.fromOffset(18, 2)
						knob.BackgroundColor3 = Color3.fromRGB(17, 17, 17)
					end
					
					switch.MouseButton1Click:Connect(function()
						on = not on
						updateToggle()
					end)
					
					function ToggleFunctions:SetValue(val)
						if on ~= val then
							on = val
							updateToggle()
						end
					end
					
					if flag then CryptHub.Options[flag] = ToggleFunctions end
					return ToggleFunctions
				end
				
				function SectionFunctions:Slider(sliderSettings, flag)
					local SliderFunctions = {Value = sliderSettings.Default or sliderSettings.Minimum or 0}
					
					local sliderRow = Instance.new("Frame")
					sliderRow.Name = "Slider"
					sliderRow.BackgroundTransparency = 1
					sliderRow.Size = UDim2.new(1, 0, 0, 40)
					sliderRow.Parent = sectionPanel
					
					local label = Instance.new("TextLabel")
					label.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json")
					label.Text = sliderSettings.Name or "Slider"
					label.TextColor3 = Color3.fromRGB(150, 150, 150)
					label.TextSize = 13
					label.TextXAlignment = Enum.TextXAlignment.Left
					label.BackgroundTransparency = 1
					label.Size = UDim2.new(1, -40, 0, 18)
					label.Parent = sliderRow
					
					local valueLabel = Instance.new("TextLabel")
					valueLabel.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json")
					valueLabel.Text = tostring(SliderFunctions.Value)
					valueLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
					valueLabel.TextSize = 13
					valueLabel.TextTransparency = 0.4
					valueLabel.TextXAlignment = Enum.TextXAlignment.Right
					valueLabel.BackgroundTransparency = 1
					valueLabel.AnchorPoint = Vector2.new(1, 0)
					valueLabel.Position = UDim2.fromScale(1, 0)
					valueLabel.Size = UDim2.fromOffset(40, 18)
					valueLabel.Parent = sliderRow
					
					local track = Instance.new("Frame")
					track.Name = "Track"
					track.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
					track.BackgroundTransparency = 0.85
					track.BorderSizePixel = 0
					track.Position = UDim2.fromOffset(0, 26)
					track.Size = UDim2.new(1, 0, 0, 4)
					track.Parent = sliderRow
					
					local trackCorner = Instance.new("UICorner")
					trackCorner.CornerRadius = UDim.new(1, 0)
					trackCorner.Parent = track
					
					local fill = Instance.new("Frame")
					fill.Name = "Fill"
					fill.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
					fill.BackgroundTransparency = 0.15
					fill.BorderSizePixel = 0
					fill.Size = UDim2.fromScale((SliderFunctions.Value - (sliderSettings.Minimum or 0)) / ((sliderSettings.Maximum or 100) - (sliderSettings.Minimum or 0)), 1)
					fill.Parent = track
					
					local fillCorner = Instance.new("UICorner")
					fillCorner.CornerRadius = UDim.new(1, 0)
					fillCorner.Parent = fill
					
					local thumb = Instance.new("Frame")
					thumb.Name = "Thumb"
					thumb.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
					thumb.BorderSizePixel = 0
					thumb.AnchorPoint = Vector2.new(0.5, 0.5)
					thumb.Position = UDim2.fromScale(fill.Size.X.Scale, 0.5)
					thumb.Size = UDim2.fromOffset(12, 12)
					thumb.Parent = track
					
					local thumbCorner = Instance.new("UICorner")
					thumbCorner.CornerRadius = UDim.new(1, 0)
					thumbCorner.Parent = thumb
					
					local min, max = sliderSettings.Minimum or 0, sliderSettings.Maximum or 100
					
					local function updateSlider(input)
						local pos = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
						local val = math.round(min + (max - min) * pos)
						SliderFunctions.Value = val
						fill.Size = UDim2.fromScale(pos, 1)
						thumb.Position = UDim2.fromScale(pos, 0.5)
						valueLabel.Text = tostring(val)
						if sliderSettings.Callback then sliderSettings.Callback(val) end
					end
					
					local dragging = false
					track.InputBegan:Connect(function(input)
						if input.UserInputType == Enum.UserInputType.MouseButton1 then
							dragging = true
							updateSlider(input)
						end
					end)
					
					UserInputService.InputChanged:Connect(function(input)
						if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
							updateSlider(input)
						end
					end)
					
					UserInputService.InputEnded:Connect(function(input)
						if input.UserInputType == Enum.UserInputType.MouseButton1 then
							dragging = false
						end
					end)
					
					if flag then CryptHub.Options[flag] = SliderFunctions end
					return SliderFunctions
				end
				
				return SectionFunctions
			end
			
			return TabFunctions
		end
		
		return TabGroupFunctions
	end

	return WindowFunctions
end

return CryptHub
