		local notifDesc = Instance.new("TextLabel")
		notifDesc.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json")
		notifDesc.Text = notifySettings.Description or ""
		notifDesc.TextColor3 = Color3.fromRGB(255, 255, 255)
		notifDesc.TextSize = 12
		notifDesc.TextTransparency = 0.4
		notifDesc.TextWrapped = true
		notifDesc.BackgroundTransparency = 1
		notifDesc.Position = UDim2.fromOffset(15, 35)
		notifDesc.Size = UDim2.new(1, -30, 0, 35)
		notifDesc.Parent = notif
		
		notif.Parent = notifications
		
		task.delay(notifySettings.Lifetime or 5, function()
			Tween(notif, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
			for _, child in ipairs(notif:GetDescendants()) do
				if child:IsA("GuiObject") then
					Tween(child, TweenInfo.new(0.3), {TextTransparency = 1, ImageTransparency = 1}):Play()
				end
			end
			task.wait(0.3)
			notif:Destroy()
		end)
	end
	
