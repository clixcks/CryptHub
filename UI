	end

	function WindowFunctions:SetUserInfoState(enabled)
		if userInfoFrame then
			userInfoFrame.Visible = enabled
		end
	end

	function WindowFunctions:GetUserInfoState()
		return userInfoFrame and userInfoFrame.Visible or false
	end

	WindowFunctions.Settings = Settings

	return WindowFunctions
