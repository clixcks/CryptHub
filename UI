function CryptHub:SetFolder(folder)
	CryptHub.Folder = folder
	if not isStudio then
		if not isfolder(folder) then
			makefolder(folder)
			makefolder(folder .. "/settings")
			makefolder(folder .. "/configs")
		end
	end
end

function CryptHub:SaveConfig(name)
	if isStudio then return false, "Studio mode" end
	if not isfolder(CryptHub.Folder) then makefolder(CryptHub.Folder) end
	if not isfolder(CryptHub.Folder .. "/configs") then makefolder(CryptHub.Folder .. "/configs") end
	
	local config = {}
	for flag, option in pairs(CryptHub.Options) do
		if option.Class == "Toggle" then
			config[flag] = option.Value
		elseif option.Class == "Slider" then
			config[flag] = option.Value
		elseif option.Class == "Input" then
			config[flag] = option.Value
		elseif option.Class == "Keybind" then
			config[flag] = option.Value and option.Value.Name or nil
		elseif option.Class == "Dropdown" then
			config[flag] = option.Value
		elseif option.Class == "Colorpicker" then
			if option.Color then
				config[flag] = {
					R = option.Color.R,
					G = option.Color.G,
					B = option.Color.B,
					A = option.Alpha
				}
			end
		end
	end
	
	local success, err = pcall(function()
		writefile(CryptHub.Folder .. "/configs/" .. name .. ".json", HttpService:JSONEncode(config))
	end)
	
	return success, err
end

function CryptHub:LoadConfig(name)
	if isStudio then return false, "Studio mode" end
	if not name or not isfile(CryptHub.Folder .. "/configs/" .. name .. ".json") then
		return false, "Config not found"
	end
	
	local success, config = pcall(function()
		return HttpService:JSONDecode(readfile(CryptHub.Folder .. "/configs/" .. name .. ".json"))
	end)
	
	if not success then return false, config end
	
	for flag, value in pairs(config) do
		local option = CryptHub.Options[flag]
		if option then
			if option.Class == "Toggle" then
				option:SetValue(value)
			elseif option.Class == "Slider" then
				option:SetValue(value)
			elseif option.Class == "Input" then
				option:SetValue(value)
			elseif option.Class == "Keybind" and value then
				local keycode = Enum.KeyCode[value]
				if keycode then option:SetValue(keycode) end
			elseif option.Class == "Dropdown" then
				option:UpdateSelection(value)
			elseif option.Class == "Colorpicker" and type(value) == "table" then
				local color = Color3.fromRGB(value.R * 255, value.G * 255, value.B * 255)
				option:SetValue(color, value.A)
			end
		end
	end
	
	return true
end

function CryptHub:RefreshConfigList()
	if isStudio then return {} end
	if not isfolder(CryptHub.Folder .. "/configs") then return {} end
	
	local configs = {}
	for _, file in ipairs(listfiles(CryptHub.Folder .. "/configs")) do
		if file:match("%.json$") then
			local name = file:match("([^/\\]+)%.json$")
			if name then table.insert(configs, name) end
		end
	end
	return configs
end

function CryptHub:DeleteConfig(name)
	if isStudio then return false, "Studio mode" end
	local path = CryptHub.Folder .. "/configs/" .. name .. ".json"
	if isfile(path) then
		delfile(path)
		return true
	end
	return false, "Config not found"
end

