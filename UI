					box.ClearTextOnFocus = false
					local boxUIPadding = Instance.new("UIPadding")
					boxUIPadding.PaddingLeft = UDim.new(0, 10)
					boxUIPadding.PaddingRight = UDim.new(0, 10)
					boxUIPadding.Parent = box
					local boxUICorner = Instance.new("UICorner")
					boxUICorner.CornerRadius = UDim.new(0, 6)
					boxUICorner.Parent = box
					box.Parent = input
					local function isValidChar(char)
						local accepted = Settings.AcceptedCharacters or "All"
						if type(accepted) == "function" then return accepted(char) end
						if accepted == "Numeric" then return char:match("%d") ~= nil end
						if accepted == "Alphabetic" then return char:match("%a") ~= nil end
						if accepted == "AlphaNumeric" then return char:match("%w") ~= nil end
						return true
					end
					box:GetPropertyChangedSignal("Text"):Connect(function()
						local text = box.Text
						local filtered = ""
						for i = 1, #text do
							local char = text:sub(i, i)
							if isValidChar(char) then
								filtered = filtered .. char
							end
						end
						if filtered ~= text then
							box.Text = filtered
						end
						InputFunctions.Value = box.Text
						if Settings.onChanged then Settings.onChanged(box.Text) end
					end)
					box.FocusLost:Connect(function()
						if Settings.Callback then Settings.Callback(box.Text) end
					end)
					input.Parent = section
					function InputFunctions:SetValue(text)
						box.Text = text
						InputFunctions.Value = text
					end
					if Flag then CryptHub.Options[Flag] = InputFunctions end
					return InputFunctions
				end

